		"@types/bun": "^1.3.8",
		"@types/jsdom": "^27.0.0",
		"@types/node": "^25.2.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/coverage-v8": "^4.0.18",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
